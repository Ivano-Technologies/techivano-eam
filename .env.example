# ============================================================
# TECHIVANO EAM — ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env or .env.local. Never commit real secrets.
# Deployment strategy: docs/DEPLOYMENT_AND_BRANCH_STRATEGY.md
#
# Categories:
#   Public client  — safe for browser (VITE_*, NEXT_PUBLIC_*)
#   Server secrets — never expose (DATABASE_URL, *_SECRET_*, etc.)
#   Infrastructure — Redis, queues, logging, monitoring
# ============================================================
#
# REQUIRED vs OPTIONAL (minimal set for auth + app)
# ------------------------------------------------------------
# Required for Supabase auth and backend:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY  — client auth
#   SUPABASE_JWT_SECRET                         — server verification of tokens
#   DATABASE_URL                                — app DB (Supabase Postgres)
# Optional but recommended:
#   VITE_APP_URL, VITE_API_URL                  — app/base URL
#   REDIS_URL                                   — required for queue workers (Phases 4+)
#   SUPABASE_SERVICE_ROLE_KEY                   — admin operations
# Most other variables are optional or feature-specific (email, AI, R2, etc.).
# ------------------------------------------------------------

# ------------------------------------------------------------
# Public client variables (safe for browser)
# ------------------------------------------------------------
NODE_ENV=development
VITE_APP_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api

# CORS (production): comma-separated origins allowed to call the API.
# For multi-subdomain production (admin.techivano.com, nrcseam.techivano.com), include both hosts so browser requests are allowed.
# If unset in production, same-origin only. In development, request origin is allowed.
# ALLOWED_ORIGINS=https://admin.techivano.com,https://nrcseam.techivano.com,https://techivano.com

# Supabase (client) — use VITE_* for Vite or NEXT_PUBLIC_* for Next
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Auth login logo: optional URL override. Default is /nrcs-logo.png (place file in client/public/).
# VITE_AUTH_LOGO_URL=

# R2 public asset URL (client-safe)
R2_PUBLIC_BASE_URL=https://assets.techivano.com

# ------------------------------------------------------------
# Server secrets (never expose to client)
# ------------------------------------------------------------
# Supabase — for production (e.g. Vercel) set SUPABASE_URL so serverless functions can use the admin client (legacy migration, password update, checkRequiresPasswordSetup). Do not expose SUPABASE_SERVICE_ROLE_KEY to the client.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL_DOCKER=postgres://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
MASTER_ENCRYPTION_KEY="base64-32-byte-master-key-placeholder"

# R2 (server-only)
R2_BUCKET_NAME=techivano-assets
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# ------------------------------------------------------------
# Infrastructure variables
# ------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
QUEUE_WORKER_CONCURRENCY=4
LOG_LEVEL=info

# ------------------------------------------------------------
# Production / Intelligence Platform (Phases 4–9) — techivano.com
# ------------------------------------------------------------
# Required for deployment runbook (docs/DEPLOYMENT_RUNBOOK.md)
NODE_ENV=production
JWT_SECRET=your-jwt-secret-min-32-chars

# Manus OAuth (portal: https://manus.im)
VITE_APP_ID=YNihSyDPBSASM93ZxstDRD
VITE_OAUTH_PORTAL_URL=https://manus.im
OAUTH_SERVER_URL=https://api.manus.im

# Email — Resend (primary for techivano.com), then Forge (Manus), then SMTP fallback
# Option A (recommended): Resend — verify techivano.com at https://resend.com/domains, create API key at https://resend.com/api-keys
RESEND_API_KEY=
# From address: must use a verified domain (e.g. noreply@techivano.com)
EMAIL_FROM=noreply@techivano.com
# Option B: Forge built-in (BUILT_IN_FORGE_* from Manus dashboard)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# Option C: SMTP (e.g. SendGrid, Mailgun, or your SMTP server)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redirect URI for production: https://techivano.com/api/oauth/callback
# Must be whitelisted in Manus OAuth app settings.

# Supabase (server; client uses VITE_SUPABASE_*)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# JWT secret for server-side verification of Supabase access tokens (Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Optional: validate JWT iss/aud (e.g. iss: https://YOUR_REF.supabase.co/auth/v1, aud: authenticated)
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=

# Optional: single Google OAuth client so Google shows "continue to EAM" (docs/GOOGLE_OAUTH_CLIENT_NAME.md)
# When set, Login uses /api/auth/google instead of Supabase built-in Google provider. One client for all tenants.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Global owner emails (comma-separated). These accounts require password and 12+ char passwords; always elevated to owner.
# See docs/FINAL_AUTH_POLICY.md. If unset, defaults: kezieokpala@gmail.com, ivanonigeria@gmail.com, kezie@ivanotechnologies.com
# GLOBAL_OWNER_EMAILS=kezieokpala@gmail.com,ivanonigeria@gmail.com,kezie@ivanotechnologies.com

# E2E auth (optional; required for test:e2e:auth and CI auth-e2e workflow)
# E2E_AUTH_EMAIL= e2e@example.com
# E2E_AUTH_PASSWORD= your-secure-password
# E2E_BASE_URL= http://localhost:3000

# Redis / BullMQ (required for Phases 4–9 workers)
REDIS_URL=redis://127.0.0.1:6379
PHASE3_WORKERS_ENABLED=true

# ------------------------------------------------------------
# Authentication — Supabase Auth
# ------------------------------------------------------------
# 📄 Supabase config checklist (Site URL, Redirect URLs, Email/Google enabled): docs/FINAL_AUTH_POLICY.md
# 📄 Migration from Manus OAuth: docs/SUPABASE_AUTH_MIGRATION_PLAN.md

# Email domain whitelist for signup (HIGH-8). Comma-separated list of allowed domains (e.g. nrcs.org.ng,redcross.org).
# If unset, defaults to: redcrossnigeria.org, ifrc.org, gmail.com, icloud.com, yahoo.com, outlook.com, hotmail.com.
# ALLOWED_SIGNUP_DOMAINS=redcrossnigeria.org,ifrc.org,gmail.com,icloud.com,yahoo.com,outlook.com,hotmail.com

# Set to "true" or "1" to allow signup from any email domain (admin override / open signup). Skip domain check when set.
# OPEN_SIGNUP=false

# Subdomain → organization (docs/SUBDOMAIN_IMPLEMENTATION_PLAN.md)
# UUID for admin.techivano.com (Ivano mothership). Use canonical form 00000000-0000-4000-8000-<12 hex> for tenantId.
# HOST_ORG_ADMIN=00000000-0000-4000-8000-000000000001
# UUID for nrcseam.techivano.com (NRCS tenant).
# HOST_ORG_NRCS=00000000-0000-4000-8000-000000000002
# Allowed signup domains per subdomain (comma-separated). Admin default: ivanotechnologies.com. NRCS: uses ALLOWED_SIGNUP_DOMAINS or default list.
# ALLOWED_DOMAINS_ADMIN=ivanotechnologies.com
# ALLOWED_DOMAINS_NRCS=redcrossnigeria.org,ifrc.org,gmail.com,icloud.com,yahoo.com,outlook.com,hotmail.com

# ------------------------------------------------------------
# AI Providers (SERVER ONLY)
# ------------------------------------------------------------

# OpenAI (required if AI_ENABLED=true)
OPENAI_API_KEY=sk-dev_openai_placeholder

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=sk-ant-dev_placeholder

# AI configuration
AI_ENABLED=true
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_ENABLED=true
AI_MAX_RETRIES=3
AI_TIMEOUT_MS=30000

# ------------------------------------------------------------
# ML Service Configuration (NEW - Feb 2026 Upgrade)
# ------------------------------------------------------------

# URL for the ML inference service
ML_SERVICE_URL=http://localhost:5000

# Confidence threshold for auto-accepting ML categorizations (0.0 to 1.0)
# Recommendations with confidence >= this threshold will be auto-accepted
ML_AUTO_ACCEPT_THRESHOLD=0.80

# Confidence threshold for suggesting ML categorizations (0.0 to 1.0)
# Recommendations with confidence >= this threshold will be suggested to users
ML_SUGGEST_THRESHOLD=0.50

# ------------------------------------------------------------
# LLM Categorization Configuration (NEW - Feb 2026 Upgrade)
# ------------------------------------------------------------

# Confidence threshold for auto-accepting LLM categorizations (0-100)
# Recommendations with confidence >= this threshold will be auto-accepted
LLM_AUTO_ACCEPT_THRESHOLD=80

# LLM categorization suggestion threshold (0-100)
LLM_SUGGEST_THRESHOLD=50

# ------------------------------------------------------------
# Duplicate Detection Configuration (NEW - Feb 2026 Upgrade)
# ------------------------------------------------------------

# Similarity threshold for duplicate detection (0.0 to 1.0)
# Transactions with similarity >= this threshold are considered duplicates
DUPLICATE_SIMILARITY_THRESHOLD=0.85

# ------------------------------------------------------------
# Feature Flags (Client-safe)
# ------------------------------------------------------------

VITE_ENABLE_AI_CATEGORIZATION=true
VITE_ENABLE_PDF_PARSING=true
VITE_ENABLE_MULTI_USER=false

# NEW Feature Flags (Feb 2026 Upgrade)
ENABLE_PDF_OCR=true
ENABLE_LSH_OPTIMIZATION=true
ENABLE_ENSEMBLE_CATEGORIZATION=true
ENABLE_QUALITY_MONITORING=true

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AI_TOKENS_PER_REQUEST=4000

# ------------------------------------------------------------
# Banking — Mono Connect (Financial Data)
# ------------------------------------------------------------

# Server-only
MONO_SECRET_KEY=test_sk_mono_placeholder

# Client-safe (used in Mono Connect widget)
VITE_MONO_PUBLIC_KEY=test_pk_mono_placeholder

# ------------------------------------------------------------
# Payments (Paystack)
# ------------------------------------------------------------

# Server-only
PAYSTACK_SECRET_KEY=sk_dev_paystack_placeholder
PAYSTACK_WEBHOOK_SECRET=dev_webhook_secret_placeholder

# Client-safe
VITE_PAYSTACK_PUBLIC_KEY=pk_dev_paystack_public_placeholder

# ------------------------------------------------------------
# Analytics & Monitoring
# ------------------------------------------------------------

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

LOG_LEVEL=info

# ------------------------------------------------------------
# Background Jobs / Queue (BullMQ + Redis)
# ------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
QUEUE_WORKER_CONCURRENCY=4
QUEUE_DEFAULT_ATTEMPTS=5
PHASE3_WORKERS_ENABLED=false

# Sentry — Error Tracking & Performance Monitoring
# Get DSN from: sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
# Get auth token from: sentry.io → Settings → Auth Tokens
# Only needed in CI/Vercel for source map uploads
SENTRY_AUTH_TOKEN=sntrys_xxx

# ------------------------------------------------------------
# Test (optional — for DB-dependent tests)
# ------------------------------------------------------------
# Run: pnpm test
# When DATABASE_URL is set and valid (no YOUR_PASSWORD / YOUR_PROJECT_REF),
# vitest runs DB-dependent tests (eam, notifications, qrcode, bulkSiteImport,
# auth.password, auth.passwordReset, etc.). Otherwise those tests are skipped.
# Note: server/db uses Drizzle with mysql2 driver; DB-dependent tests expect
# MySQL or a compatible schema. For CI without a DB, leave DATABASE_URL unset
# or use a placeholder so DB-dependent tests are excluded and CI passes.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================================
# NOTES FOR NEW ENVIRONMENT VARIABLES 
# ============================================================
#
# ML_AUTO_ACCEPT_THRESHOLD & ML_SUGGEST_THRESHOLD:
#   - Range: 0.0 to 1.0 (e.g., 0.80 = 80% confidence)
#   - Higher = more conservative (fewer auto-categorizations)
#   - Lower = more aggressive (more auto-categorizations)
#   - Recommended: 0.80 for production, 0.90 for testing
#
# LLM_AUTO_ACCEPT_THRESHOLD:
#   - Range: 0 to 100 (for backward compatibility)
#   - Same logic as ML thresholds
#   - Recommended: 80 for production, 90 for testing
#
# DUPLICATE_SIMILARITY_THRESHOLD:
#   - Range: 0.0 to 1.0 (e.g., 0.85 = 85% similarity required)
#   - Higher = stricter duplicate detection (fewer false positives)
#   - Lower = looser duplicate detection (catches more duplicates)
#   - Recommended: 0.85 for production, 0.90 for testing
#
# ENABLE_PDF_OCR:
#   - true: Enable OCR fallback for scanned PDFs (requires tesseract.js)
#   - false: Only extract text from text-based PDFs
#
# ENABLE_LSH_OPTIMIZATION:
#   - true: Use LSH algorithm for duplicate detection (faster for large datasets)
#   - false: Use traditional O(n²) algorithm (simpler, works for all sizes)
#
# ENABLE_ENSEMBLE_CATEGORIZATION:
#   - true: Use LLM → Rule → ML fallback chain (higher accuracy)
#   - false: Use single categorization method
#
# ENABLE_QUALITY_MONITORING:
#   - true: Track and report data quality metrics
#   - false: Disable quality monitoring
#
# ============================================================
